APP_ENV=development

API_URL=http://backend:8000
API_TOKEN=..

BOT_TOKEN=..

POSTGRES_DB=vpn_bot
POSTGRES_USER=vpn_bot_user
POSTGRES_PASSWORD=..
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vpn_bot_user:${POSTGRES_PASSWORD}@postgres:5432/vpn_bot

BACKEND_PORT=8000

DOCKERHUB_USERNAME=maximylis

# VPN_MANAGER_URL=http://host.docker.internal:9000
VPN_MANAGER_URL=http://vpn-manager:9000
VPN_MANAGER_API_TOKEN=..

WG_INTERFACE=wg0
WG_NETWORK=10.0.0.0/24
WG_SERVER_PUBLIC_KEY=..
WG_ENDPOINT=..:51820
WG_CLIENT_DNS=1.1.1.1
WG_CLIENT_ALLOWED_IPS=0.0.0.0/0
WG_STATE_DIR=/var/lib/vpn-manager/peers
WG_APPLY_CHANGES=false
